# Public (safe for browser)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
# Preferred (new Supabase naming)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Optional legacy fallback
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Backend API integration
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
# Optional explicit override. If empty, derived from NEXT_PUBLIC_API_BASE_URL.
NEXT_PUBLIC_MATCHING_WS_URL=ws://localhost:8000/api/v1/matching/ws

# Domain gating
# true: only ALLOWED_EMAIL_DOMAIN can access after OAuth callback
# false: allow any Google account (for demo/dev)
ENFORCE_DOMAIN_RESTRICTION=true
ALLOWED_EMAIL_DOMAIN=@vitbhopal.ac.in

# UI-only developer shortcut. Keep false in production.
NEXT_PUBLIC_DEV_MODE=false
